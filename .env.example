# ── Database ────────────────────────────────────────────────
# Paste your Supabase "Transaction" connection string here.
# Found in: Supabase Dashboard → Settings → Database → Connection string → URI
# It looks like: postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
DATABASE_URL=postgresql://postgres.<project-ref>:<url-encoded-password>@aws-0-<region>.pooler.supabase.com:6543/postgres
# ── Session ─────────────────────────────────────────────────
# Any long random string (run: openssl rand -base64 32)
SESSION_SECRET=rzPdaMYP+ML6u2p3qYDvO/ZZ+9eRcwfgHW+qVE2rlsBU

# ── Temporary Admin Login (Frontend) ──────────────────────────
# NOTE: Vite only exposes vars prefixed with VITE_ to client code.
VITE_ADMIN_ID=CCE001
VITE_ADMIN_PASSWORD=CharlesAdmin#2026

# API base URL for production (e.g. Vercel frontend + separate API host).
# If unset, the web app calls relative `/api/*` (works only when the API is on the same domain,
# or when your host provides rewrites).
# Example: VITE_API_BASE_URL=https://your-api.example.com
# VITE_API_BASE_URL=

# Public URL to encode in the printable QR poster.
# Set this to your custom domain so the poster always points to production even
# when opened from a Vercel preview URL.
VITE_PUBLIC_APP_URL=https://charlescheckin.inkaastudio.com

# ── API Server (CORS) ─────────────────────────────────────────
# Optional: allow custom frontend domains in production (comma-separated).
# Example: CORS_ORIGINS=https://charles.example.com,https://staging-charles.example.com
# CORS_ORIGINS=
